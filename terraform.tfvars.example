# ── Required ─────────────────────────────────────────────────────────────────
project_id      = "your-gcp-project-id"
service_account = "SERVICE_ACCOUNT@your-gcp-project-id.iam.gserviceaccount.com"
partner            = "your-company-name"
agileday_base_url  = "https://api.agileday.example.com"

# ── Images ───────────────────────────────────────────────────────────────────
image_tags = {
  agileday    = "v3.12.1"
  pyry        = "v1.4.1"
  network_mcp = "v0.8.0"
  minna       = "v1.3.0"
  bench_mcp   = "v1.5.0"
  topi        = "v1.5.0"
}

# ── Optional ─────────────────────────────────────────────────────────────────
region       = "europe-north1"
gemini_model = "gemini-2.5-flash"

# Rakettitiede only: other partners' mcp-talent-network node URLs that Minna federates over.
# The local node is added automatically; list only the OTHER partners here.
# partner_mcp_urls = ["https://mcp-talent-network-<partner>-xxxx.europe-north1.run.app"]
